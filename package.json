{
  "name": "supertabs",
  "displayName": "Supertabs",
  "description": "Run your command center directly from your IDE",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/shekit/supertabs.git"
  },
  "keywords": [
    "reddit",
    "claude",
    "anthropic",
    "ai",
    "feed",
    "marketing"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "supertabs.authenticate",
        "title": "Supertabs: Authenticate with Reddit"
      },
      {
        "command": "supertabs.testFetch",
        "title": "Supertabs: Fetch from Reddit"
      },
      {
        "command": "supertabs.openFeed",
        "title": "Supertabs: Open Reddit Feed"
      },
      {
        "command": "supertabs.logout",
        "title": "Supertabs: Logout from Reddit"
      },
      {
        "command": "supertabs.test",
        "title": "Supertabs: Test"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0"
  }
}
